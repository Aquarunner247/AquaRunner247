# Copy to ".env" and fill in values. (This file grew when Supabase Auth + seeding were added.)
#
# PostgreSQL (Supabase: pooled connection string is fine for Prisma in many setups; add ?pgbouncer=true if required)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only: never expose to the browser. Used by prisma/seed.ts to create dev Auth users.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Password for seeded Auth users (pool-admin@ / pool-office@ / pool-tech@ example.com)
SEED_DEV_PASSWORD="change-me-long-random"

# Supabase Dashboard → Authentication → URL Configuration:
# - Site URL: http://localhost:3000
# - Redirect URLs: http://localhost:3000/auth/callback
