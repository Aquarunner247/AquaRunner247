# =============================================================================
# SETUP: Copy this file to ".env" in the project root and replace placeholders.
#   cp .env.example .env
# Next.js loads only ".env" (and .env.local for overrides). Never commit real .env.
# =============================================================================

# --- REQUIRED: Database (Prisma) ---
# Supabase: Project Settings → Database → URI (pooled is OK; add ?pgbouncer=true if your host requires it)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
#
# Prisma 7 + pg: remote DATABASE_URL hosts (anything other than localhost/127.0.0.1 without sslmode=) use
# ssl: { rejectUnauthorized: false } by default to avoid "self-signed certificate in certificate chain" (P1011).
# Strict verification: DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Force relax: DATABASE_SSL_REJECT_UNAUTHORIZED=false
# Local Postgres without TLS: use host localhost or 127.0.0.1 and omit sslmode= from the URL.

# Public site URL (used in links, callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- REQUIRED: Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# --- Server-only (never expose to the browser) ---
# Service role: used by prisma/seed.ts to create dev Auth users — keep secret.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Password used when seeding demo logins (pool-admin@ / pool-office@ / pool-tech@ example.com)
SEED_DEV_PASSWORD="change-me-long-random"

# --- Supabase Auth URLs (Dashboard → Authentication → URL Configuration) ---
# Site URL:        http://localhost:3000
# Redirect URLs:  http://localhost:3000/auth/callback

# --- OPTIONAL: OpenStreetMap Nominatim (address search + geocoding for route maps) ---
# No API key required. Nominatim asks for a descriptive User-Agent (app name + contact).
# If unset, the app uses a built-in default string.
# https://operations.osmfoundation.org/policies/nominatim/
# NOMINATIM_USER_AGENT="YourCompany AquaRunner/1.0 (you@yourdomain.com)"

# --- REQUIRED for self-serve signup/billing: Stripe (Dashboard → Developers → API keys) ---
STRIPE_SECRET_KEY="sk_test_..."
# Dashboard → Developers → Webhooks → your endpoint → Signing secret (or `stripe listen` output locally)
STRIPE_WEBHOOK_SECRET="whsec_..."
# The one flat-price Price ID for the subscription plan, created in your own Stripe dashboard
STRIPE_PRICE_ID="price_..."
