// AquaRunner 24/7 Pro — PostgreSQL (Supabase-ready)
// Service days: 1–7 weekdays per body of water (ISO 8601: 1=Mon … 7=Sun), validated in app: 1–7 rows, unique.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OFFICE
  TECHNICIAN
}

enum BodyOfWaterType {
  POOL
  SPA
  FOUNTAIN
  WATER_FEATURE
  OTHER
}

enum EquipmentKind {
  PUMP
  FILTER
  HEATER
  CHLORINATOR
  AUTOMATION
  FLOW_METER
  MAIN_DRAIN_COVER
  SKIMMER_COVER
  VALVE
  OTHER
}

enum FilterMedia {
  SAND
  CARTRIDGE
  DE
}

/// For pools with a spa: whether a pump/main drain serves the filtration loop or the jets
enum EquipmentPurpose {
  FILTRATION
  JETS
}

enum ScheduleFrequency {
  WEEKLY
  BIWEEKLY
  CUSTOM
}

enum VisitStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  customers Customer[]
  properties Property[]
  managementCompanies ManagementCompany[]
  chemicalProducts ChemicalProduct[]
  checklistItems ChecklistItemDefinition[]
}

model ManagementCompany {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name  String
  phone String?
  email String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Supabase Auth user id (`auth.users.id`) — set after user is created in Supabase
  authUserId String? @unique @db.Uuid

  email     String   @unique
  name      String?
  role      UserRole @default(TECHNICIAN)
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedVisits ServiceVisit[] @relation("VisitTechnician")
  assignedRoutes RecurringRoute[] @relation("RouteTechnician")
  sentAlerts     CustomerAlert[]

  @@index([organizationId])
}

model Customer {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name       String
  billingRef String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  properties     Property[]
  documents      CustomerDocument[]
  customerUsers  CustomerUser[]
  alerts         CustomerAlert[]

  @@index([organizationId])
}

/// A customer-portal login (separate from staff `User`) — a customer's own contact who can
/// sign in at /portal to see their scheduled visits, reports, photos, documents, and alerts.
model CustomerUser {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  /// Supabase Auth user id — set after the login is created in Supabase
  authUserId String? @unique @db.Uuid
  email      String  @unique
  name       String?
  active     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
}

/// A one-way admin -> customer message, shown in the customer's portal and emailed.
model CustomerAlert {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdByUserId String?
  createdBy       User?   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  subject String
  message String

  createdAt DateTime @default(now())

  @@index([customerId])
}

/// Uploaded files (inspection reports, contracts, etc.) shown on a customer's Overview tab.
/// Binary content lives in Supabase Storage; this row is just the pointer + metadata.
model CustomerDocument {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  label       String
  storagePath String
  contentType String?
  fileSize    Int?

  createdAt DateTime @default(now())

  @@index([customerId])
}

model Property {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  name                  String
  managerName           String?
  managerBusinessPhone  String?
  managerMobilePhone    String?
  managerPhone          String?
  managerEmail          String?
  /// On-site maintenance contact — separate from the property manager above.
  maintenanceName       String?
  maintenanceCellPhone  String?
  maintenanceEmail      String?
  managementCompanyId String?
  managementCompany   ManagementCompany? @relation(fields: [managementCompanyId], references: [id], onDelete: SetNull)
  addressLine1          String?
  addressLine2          String?
  city                  String?
  region                String?
  postalCode            String?
  country               String? @default("US")
  latitude              Decimal? @db.Decimal(10, 7)
  longitude             Decimal? @db.Decimal(10, 7)
  geofenceMeters        Int?
  notes                 String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bodiesOfWater  BodyOfWater[]
  visits         ServiceVisit[]
  recurringStops RecurringStop[]

  @@index([organizationId])
  @@index([customerId])
  @@index([managementCompanyId])
}

model BodyOfWater {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  name         String
  type         BodyOfWaterType @default(POOL)
  volumeGallons Decimal?        @db.Decimal(12, 2)
  /// SNHD-posted maximum bather load for this body of water
  maximumOccupancy Int?
  notes        String?

  /// SNHD log footer: minimum required recirculation flow (GPM)
  minimumRequiredFlowGpm Decimal? @db.Decimal(10, 2)
  /// SNHD log footer: maximum filter flow (GPM)
  maximumFilterFlowGpm   Decimal? @db.Decimal(10, 2)

  /// Public, unguessable slug used for this body of water's QR code / inspector log page
  publicSlug String @unique @default(cuid())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipment       Equipment[]
  serviceWeekdays BodyOfWaterServiceWeekday[]
  visits          ServiceVisit[]
  recurringStops  RecurringStop[]

  @@index([propertyId])
}

/// Which weekdays this body is serviced (1=Mon … 7=Sun). Enforce 1–7 distinct rows in application layer.
model BodyOfWaterServiceWeekday {
  id            String      @id @default(cuid())
  bodyOfWaterId String
  bodyOfWater   BodyOfWater @relation(fields: [bodyOfWaterId], references: [id], onDelete: Cascade)

  /// ISO 8601 weekday: 1 = Monday through 7 = Sunday
  weekday   Int
  createdAt DateTime @default(now())

  @@unique([bodyOfWaterId, weekday])
  @@index([bodyOfWaterId])
}

model Equipment {
  id            String      @id @default(cuid())
  bodyOfWaterId String
  bodyOfWater   BodyOfWater @relation(fields: [bodyOfWaterId], references: [id], onDelete: Cascade)

  kind         EquipmentKind @default(OTHER)
  make         String?
  model        String?
  serialNumber String?
  /// For main drain covers, skimmer covers, and valves
  numberOfPorts Int?
  /// Pipe sizing, e.g. "2 in"
  pipeSize      String?
  /// Date this item was last changed, serviced, or fixed
  lastServicedAt DateTime?
  installedOn  DateTime?
  notes        String?

  /// Pump: motor horsepower
  horsepower Decimal? @db.Decimal(6, 2)
  /// Pump: e.g. "115V", "230V", "115/230V"
  voltage String?

  /// Heater: BTU rating
  btu Int?
  /// Heater: ASME-certified pressure vessel
  asmeCertified Boolean?

  /// Main drain cover: VGB Act compliance year (2008 or 2017)
  vgbaYear Int?
  /// Main drain cover: manufactured sump (vs. field-built)
  manufacturedSump Boolean?
  /// Main drain cover: max GPM flow rate (shown in place of serial # for this kind)
  flowRateGpm Decimal? @db.Decimal(10, 2)

  /// Skimmer cover: equalizer line abandoned
  equalizerAbandoned Boolean?

  /// Filter: media type (shown in place of serial # for this kind)
  filterMedia FilterMedia?

  /// Valve: how many of this same valve are installed
  quantity Int?

  /// Spa only — Pump / Main Drain Cover: whether this serves filtration or jets
  purpose EquipmentPurpose?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceEvents EquipmentServiceEvent[]

  @@index([bodyOfWaterId])
}

model EquipmentServiceEvent {
  id          String    @id @default(cuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  performedAt       DateTime @default(now())
  summary           String
  details           String?
  performedByUserId String?

  @@index([equipmentId])
}

model RecurringRoute {
  id             String @id @default(cuid())
  organizationId String

  name      String
  /// Default assigned technician for generated visits (1 route per tech per day).
  technicianId String?
  technician   User?   @relation("RouteTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  frequency ScheduleFrequency @default(WEEKLY)
  dayOfWeek Int?
  active    Boolean           @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stops RecurringStop[]

  @@index([organizationId])
  @@index([technicianId])
}

model RecurringStop {
  id      String         @id @default(cuid())
  routeId String
  route   RecurringRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  bodyOfWaterId String?
  bodyOfWater   BodyOfWater? @relation(fields: [bodyOfWaterId], references: [id], onDelete: SetNull)

  sortOrder        Int @default(0)
  etaOffsetMinutes Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visits ServiceVisit[]

  @@index([routeId])
  @@index([propertyId])
}

model ServiceVisit {
  id             String @id @default(cuid())
  organizationId String

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  bodyOfWaterId String
  bodyOfWater   BodyOfWater @relation(fields: [bodyOfWaterId], references: [id], onDelete: Cascade)

  technicianId String?
  technician   User?   @relation("VisitTechnician", fields: [technicianId], references: [id], onDelete: SetNull)

  /// When set, this visit was created from a weekly route stop (for idempotent generation).
  recurringStopId String?
  recurringStop   RecurringStop? @relation(fields: [recurringStopId], references: [id], onDelete: SetNull)

  /// Route stop order for the day (tech can reorder). Lower runs first.
  routeSequence Int @default(0)

  scheduledStart DateTime
  scheduledEnd   DateTime?

  status          VisitStatus @default(SCHEDULED)
  serviceComplete Boolean     @default(false)
  techNotes       String?

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reading         VisitWaterReading?
  doses           VisitChemicalDose[]
  photos          VisitPhoto[]
  issues          VisitIssueFlag[]
  recommendation ChemistryRecommendation?
  checklistCompletions VisitChecklistCompletion[]

  @@index([organizationId, scheduledStart])
  @@index([technicianId, scheduledStart])
  @@index([propertyId, scheduledStart])
  @@index([bodyOfWaterId, scheduledStart])
  @@index([recurringStopId, scheduledStart])
}

model VisitWaterReading {
  id      String       @id @default(cuid())
  visitId String       @unique
  visit   ServiceVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  ph               Decimal? @db.Decimal(4, 2)
  freeChlorinePpm  Decimal? @db.Decimal(6, 2)
  totalChlorinePpm Decimal? @db.Decimal(6, 2)
  alkalinityPpm    Decimal? @db.Decimal(8, 2)
  cyanuricAcidPpm  Decimal? @db.Decimal(8, 2)
  /// Optional — not required for your SNHD workflow
  temperatureF     Decimal? @db.Decimal(5, 2)

  filterPressurePsi  Decimal? @db.Decimal(6, 2)
  vacGaugeReading    Decimal? @db.Decimal(6, 2)
  pumpPressurePsi    Decimal? @db.Decimal(6, 2)
  filterGaugeReading Decimal? @db.Decimal(6, 2)
  flowMeterGpm       Decimal? @db.Decimal(8, 2)

  /// SNHD: time of backwash (if performed this visit)
  backwashAt DateTime?

  capturedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ChemicalProduct {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name          String
  unit          String
  costPerUnit   Decimal @db.Decimal(10, 4)
  chargePerUnit Decimal @db.Decimal(10, 4)
  active        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doses VisitChemicalDose[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model VisitChemicalDose {
  id      String       @id @default(cuid())
  visitId String
  visit   ServiceVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  chemicalProductId String?
  chemicalProduct   ChemicalProduct? @relation(fields: [chemicalProductId], references: [id], onDelete: SetNull)

  productName String
  quantity    Decimal @db.Decimal(12, 4)
  unit        String
  /// Cost/charge per unit, snapshotted at the time this dose was logged so
  /// historical billing stays accurate even if catalog prices change later.
  unitCost    Decimal? @db.Decimal(10, 4)
  unitCharge  Decimal? @db.Decimal(10, 4)

  createdAt DateTime @default(now())

  @@index([visitId])
  @@index([chemicalProductId])
}

model VisitPhoto {
  id      String       @id @default(cuid())
  visitId String
  visit   ServiceVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  storagePath    String
  contentType    String?
  takenAt        DateTime?
  latitude       Decimal? @db.Decimal(10, 7)
  longitude      Decimal? @db.Decimal(10, 7)
  accuracyMeters Decimal? @db.Decimal(8, 2)

  createdAt DateTime @default(now())

  @@index([visitId])
}

model VisitIssueFlag {
  id      String       @id @default(cuid())
  visitId String
  visit   ServiceVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  code        String
  description String?
  severity    IssueSeverity @default(MEDIUM)

  resolved   Boolean   @default(false)
  resolvedAt DateTime?

  createdAt DateTime @default(now())

  @@index([visitId])
  @@index([resolved])
}

model ChemistryRecommendation {
  id      String       @id @default(cuid())
  visitId String       @unique
  visit   ServiceVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  payload   Json
  createdAt DateTime @default(now())
}

model ChecklistItemDefinition {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  label     String
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  completions VisitChecklistCompletion[]

  @@index([organizationId])
}

model VisitChecklistCompletion {
  id      String       @id @default(cuid())
  visitId String
  visit   ServiceVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  checklistItemId String?
  checklistItem   ChecklistItemDefinition? @relation(fields: [checklistItemId], references: [id], onDelete: SetNull)

  /// Snapshot of the item's label at completion time, so history stays intact
  /// even if the checklist item definition is later deleted.
  label String @default("")

  completed Boolean @default(false)

  @@unique([visitId, checklistItemId])
  @@index([visitId])
  @@index([checklistItemId])
}
